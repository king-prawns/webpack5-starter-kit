  "license": "MIT",
  "homepage": "https://github.com/king-prawns/webpack5-starter-kit#readme",
  "ava": {
    "files": [
      "./src/**/*test.js"
    ],
    "failFast": true,
    "failWithoutAssertions": false,
    "require": [
      "@babel/register"
    ]
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-transform-runtime": "7.29.0",
